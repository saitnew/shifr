{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "isInvisible": { "type": "boolean" },
        "isAdmin": { "type": "boolean" },
        "isBlocked": { "type": "boolean" },
        "permanentToken": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "username", "createdAt"]
    },
    "AdminToken": {
      "title": "AdminToken",
      "description": "A temporary token generated by an admin",
      "type": "object",
      "properties": {
        "value": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "number" },
        "expiresAt": { "type": "number" }
      },
      "required": ["value", "createdBy", "createdAt", "expiresAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between users",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "name": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "creatorId": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "number" },
        "order": { "type": "object", "additionalProperties": { "type": "number" } },
        "cooldowns": { "type": "object", "additionalProperties": { "type": "number" } },
        "statuses": { "type": "object", "additionalProperties": { "type": "string" } }
      },
      "required": ["participants", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message in a chat",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "audioData": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["chatId", "senderId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles"
    },
    "/adminTokens/{tokenId}": {
      "schema": { "$ref": "#/entities/AdminToken" },
      "description": "Stores temporary admin tokens"
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Stores chat metadata"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Stores messages for a specific chat"
    }
  }
}
